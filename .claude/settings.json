{
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true
  },
  "permissions": {
    "deny": [
      "Read(.env)",
      "Read(.env.local)",
      "Read(.env.*.local)",
      "Read(**/.env)",
      "Read(**/.env.local)",
      "Read(**/.env.*.local)",
      "Read(**/credentials.json)",
      "Read(**/credentials.yml)",
      "Read(**/credentials.yaml)",
      "Read(**/*credentials*)",
      "Read(**/secrets.json)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/id_rsa)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/scripts/tdd-reminder.cjs 2>/dev/null || true",
            "statusMessage": "TDD 규칙 확인 중..."
          }
        ]
      }
    ]
  }
}
